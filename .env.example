# ============================================
# InfraWatch AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# ===========================================
# Azure Resource Group
# ===========================================
# Key resources you'll need:
#   Azure OpenAI / AI Services resource
#   Application Insights (optional)
#   Storage Account (optional)
#   Container Registry (for ACA deployment)
#   Container App Environment (for ACA deployment)
# ===========================================

# ===========================================
# Microsoft AI Foundry Configuration
# ===========================================

# Project Connection String (from AI Foundry portal > Project > Settings)
AZURE_AI_PROJECT_CONNECTION_STRING=<endpoint>;<subscription-id>;<resource-group>;<project-name>

# Azure OpenAI Endpoint (your AI Services resource)
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/

# API Key (from Azure portal > your AI Services resource > Keys)
AZURE_AI_API_KEY=your-api-key-here

# Model Deployment Name
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ===========================================
# Azure Content Safety (Responsible AI)
# ===========================================
# Uses the same AI Services resource as your Foundry project
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-ai-services-resource.services.ai.azure.com
AZURE_CONTENT_SAFETY_KEY=your-content-safety-key-here

# ===========================================
# Azure Monitor / Application Insights
# ===========================================
# From your Application Insights resource > Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ===========================================
# Azure Table Storage (optional)
# ===========================================
AZURE_STORAGE_CONNECTION_STRING=

# ===========================================
# MCP Server Configuration (READ-ONLY)
# ===========================================
INFRAWATCH_MCP_ENDPOINT=https://infrawatch-mcp.<your-env>.eastus.azurecontainerapps.io/mcp

# ===========================================
# Azure Authentication
# ===========================================
# For local dev: just run  az login
# For CI/CD: use Service Principal
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=

# ===========================================
# Dataverse Configuration (Power Platform)
# ===========================================
# DATAVERSE_URL=https://your-org.crm.dynamics.com

# ===========================================
# Development Settings
# ===========================================
REACT_APP_INFRAWATCH_MCP_ENDPOINT=https://infrawatch-mcp.<your-env>.eastus.azurecontainerapps.io/mcp
# For local dev use http://localhost:8100; for deployed agents use ACA URL:
REACT_APP_AGENT_API_URL=http://localhost:8100
# REACT_APP_AGENT_API_URL=https://infrawatch-agents.<your-env>.eastus.azurecontainerapps.io
REACT_APP_DEBUG_MODE=true

# Map Center (Lake Forest, IL)
REACT_APP_MAP_CENTER_LAT=42.2586
REACT_APP_MAP_CENTER_LNG=-87.8407
REACT_APP_MAP_DEFAULT_ZOOM=13
