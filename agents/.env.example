# ============================================
# MAINTAIN AI - Agent Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================

# ===========================================
# Azure AI Foundry Project
# ===========================================
# From AI Foundry portal > Project > Settings > Connection String
AZURE_AI_PROJECT_CONNECTION_STRING=<endpoint>;<subscription-id>;<resource-group>;<project-name>

# Azure OpenAI Endpoint (your AI Foundry project endpoint)
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# API Key (from Azure portal > your AI Services resource > Keys)
AZURE_AI_API_KEY=your-api-key-here

# ===========================================
# MCP Server (READ-ONLY, pre-deployed)
# ===========================================
INFRAWATCH_MCP_ENDPOINT=https://infrawatch-mcp.<your-env>.eastus.azurecontainerapps.io/mcp

# ===========================================
# Model Settings
# ===========================================
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ===========================================
# Content Safety (Responsible AI)
# Uses the same AI Services resource as your Foundry project
# ===========================================
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_CONTENT_SAFETY_KEY=your-api-key-here

# ===========================================
# Agent Server
# ===========================================
AGENT_API_PORT=8100

# ===========================================
# Semantic Kernel (optional — falls back to Foundry if not set)
# ===========================================
# SK_AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
# SK_AZURE_OPENAI_API_KEY=your-sk-api-key-here
# SK_DEPLOYMENT_NAME=gpt-4o-mini
# SK_API_VERSION=2024-12-01-preview

# ===========================================
# Azure Monitor / Application Insights (optional)
# ===========================================
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ===========================================
# Azure Table Storage (optional — used for persistence)
# ===========================================
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
